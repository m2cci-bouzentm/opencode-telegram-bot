TELEGRAM_BOT_TOKEN=your_bot_token
ALLOWED_CHAT_IDS=your_telegram_user_id
OPENCODE_BIN=/home/youruser/.opencode/bin/opencode
WORK_DIR=/home/youruser
OPENCODE_TIMEOUT=300
OPENCODE_MODEL=anthropic/claude-opus-4-6
MEMORY_PATH=/home/youruser/bot/memory
EMBED_MODEL=BAAI/bge-large-en-v1.5
EMBED_DEVICE=cuda
GEMINI_API_KEY=your_gemini_key
CHAT_LOG=/home/youruser/bot/chat_history.jsonl

# STT Config — switch provider by changing STT_PROVIDER
STT_PROVIDER=parakeet
STT_PORT=8787
PARAKEET_MODEL_DIR=/home/youruser/bot/models/parakeet-v3-onnx
PARAKEET_USE_GPU=true
# To use Gemini instead: STT_PROVIDER=gemini
GEMINI_STT_MODEL=gemini-2.5-flash
