[Unit]
Description=Chromium Headless with Remote Debugging
After=network-online.target

[Service]
Type=simple
User=mohamed
ExecStart=/usr/bin/chromium --headless --no-sandbox --disable-gpu --remote-debugging-port=9222 --user-data-dir=/home/mohamed/.cache/chromium-debug
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
